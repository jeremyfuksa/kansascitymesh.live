---
import { ChevronLeft } from '@lucide/astro';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import InfoCard from '../components/InfoCard.astro';
import TipBanner from '../components/TipBanner.astro';
import MessageBanner from '../components/MessageBanner.astro';
import DiscordButton from '../components/DiscordButton.astro';
import { DISCORD_INVITE } from '../constants/discord';
import { hardware } from '../data/hardware';
---

<Layout
  title="Get started with Kansas City Meshtastic"
  description="From zero to your first transmission in about 30 minutes. Hardware, flashing, configuration, and how to say hello on the KC mesh."
  path="/getting-started"
>
  <div class="min-h-screen bg-(--neutral-950)">
    <Nav currentPage="get-started" />

    {/* Simple header */}
    <div
      class="px-4 py-12 mt-16 border-b border-white/10 bg-linear-to-b from-(--neutral-900) to-(--neutral-950)"
    >
      <div class="max-w-3xl mx-auto">
        <a
          href="/"
          class="flex items-center gap-2 text-white/70 hover:text-white transition-colors mb-8 text-sm"
        >
          <ChevronLeft class="w-4 h-4" />
          Back to home
        </a>

        <h1 class="text-5xl md:text-6xl mb-6 tracking-tight text-white">Getting Started</h1>
        <p class="text-xl text-white/70">
          From zero to your first transmission in about 30 minutes. This is the path we use in KC —
          most of it works anywhere in the US.
        </p>
      </div>
    </div>

    {/* Article content */}
    <article class="px-4 py-16 max-w-3xl mx-auto">
      {/* Step 1 */}
      <section class="mb-16">
        <h2 class="text-white mb-6">Step 1: Choose Your Hardware</h2>

        <p class="text-white/70 mb-8 leading-relaxed">Start with one device. A few favorites:</p>

        <div class="space-y-4 mb-8">
          {
            hardware.map((item) => (
              <InfoCard interactive>
                <h3 class="text-white mb-2">
                  {item.name} — {item.detailPrice}
                </h3>
                <p class="text-white/70 leading-relaxed">{item.detailDescription}</p>
              </InfoCard>
            ))
          }
        </div>

        <TipBanner>
          Most people start with a Heltec V3 or V4. It's affordable, has a screen, and you can test
          the mesh before committing to more expensive gear.
        </TipBanner>
      </section>

      {/* Step 2 */}
      <section class="mb-16">
        <h2 class="text-white mb-6">Step 2: Get Your Device</h2>

        <p class="text-white/70 mb-8 leading-relaxed">
          Three main options, depending on budget and timeline:
        </p>

        <div class="space-y-4 mb-8">
          <InfoCard interactive>
            <h3 class="text-white mb-2">AliExpress</h3>
            <p class="text-white/70 leading-relaxed">
              Cheapest prices, but 2-3 week shipping from China. Good if you're patient and want to
              save $10-20.
            </p>
          </InfoCard>

          <InfoCard interactive>
            <h3 class="text-white mb-2">Amazon</h3>
            <p class="text-white/70 leading-relaxed">
              Fast shipping (1-2 days), higher prices. Search "Heltec V3 LoRa" or "Meshtastic node"
              — watch for sellers shipping from US warehouses.
            </p>
          </InfoCard>

          <InfoCard interactive>
            <h3 class="text-white mb-2">Rokland.net</h3>
            <p class="text-white/70 leading-relaxed">
              US-based, slightly higher than AliExpress. They test each board before shipping, and
              they answer email.
            </p>
          </InfoCard>
        </div>
      </section>

      {/* Step 3 */}
      <section class="mb-16">
        <h2 class="text-white mb-6">Step 3: Flash the Firmware</h2>

        <p class="text-white/70 mb-8 leading-relaxed">
          This is easier than it sounds. Takes about 5 minutes:
        </p>

        <InfoCard padding="large" class="mb-8">
          <ol class="space-y-6">
            <li class="flex gap-4">
              <span
                class="shrink-0 w-8 h-8 rounded-full bg-(--primary-700) text-white flex items-center justify-center"
                >1</span
              >
              <div>
                <p class="text-white mb-1">
                  Go to{' '}
                  <a
                    href="https://flasher.meshtastic.org"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-(--info-400) hover:text-(--info-300) underline"
                    >flasher.meshtastic.org</a
                  >
                </p>
                <p class="text-white/50">
                  <strong>Works in Chrome or Edge</strong>. No downloads needed.
                </p>
              </div>
            </li>

            <li class="flex gap-4">
              <span
                class="shrink-0 w-8 h-8 rounded-full bg-(--primary-700) text-white flex items-center justify-center"
                >2</span
              >
              <div>
                <p class="text-white mb-1">Connect your device with a USB-C cable</p>
                <p class="text-white/50">The web flasher will detect it automatically.</p>
              </div>
            </li>

            <li class="flex gap-4">
              <span
                class="shrink-0 w-8 h-8 rounded-full bg-(--primary-700) text-white flex items-center justify-center"
                >3</span
              >
              <div>
                <p class="text-white mb-1">Select your device model and click "Flash"</p>
                <p class="text-white/50">Takes 2-3 minutes. The device will reboot when done.</p>
              </div>
            </li>
          </ol>
        </InfoCard>
      </section>

      {/* Step 4 */}
      <section class="mb-16">
        <h2 class="text-white mb-6">Step 4: Configure Your Node</h2>

        <p class="text-white/70 mb-8 leading-relaxed">
          Download the Meshtastic app for{' '}
          <a
            href="https://apps.apple.com/us/app/meshtastic/id1586432531"
            target="_blank"
            rel="noopener noreferrer"
            class="text-(--info-400) hover:text-(--info-300) underline">iOS</a
          >,{' '}
          <a
            href="https://play.google.com/store/apps/details?id=com.geeksville.mesh"
            target="_blank"
            rel="noopener noreferrer"
            class="text-(--info-400) hover:text-(--info-300) underline">Android</a
          >, or use the{' '}
          <a
            href="https://client.meshtastic.org"
            target="_blank"
            rel="noopener noreferrer"
            class="text-(--info-400) hover:text-(--info-300) underline">web client</a
          >. Connect via Bluetooth and configure these settings:
        </p>

        <div class="space-y-4 mb-8">
          <InfoCard>
            <h3 class="text-white mb-2">Set your node name</h3>
            <p class="text-white/70 leading-relaxed">
              Something recognizable. A clever or descriptive name is better than 'Meshtastic abcd'.
            </p>
          </InfoCard>

          <InfoCard>
            <h3 class="text-white mb-2">Region: United States</h3>
            <p class="text-white/70 leading-relaxed">This sets your LoRa frequency to 915 MHz.</p>
          </InfoCard>

          <InfoCard>
            <h3 class="text-white mb-2">Set position (if GPS-enabled device)</h3>
            <p class="text-white/70 leading-relaxed">
              Helps build the coverage map. Your exact location isn't shared publicly, just general
              area.
            </p>
          </InfoCard>
        </div>

        <TipBanner>
          Leave the default "Long Fast" channel preset. Until KC hits the density where we'd need to
          switch presets, that's what every node here runs.
        </TipBanner>
      </section>

      {/* Step 5 */}
      <section class="mb-16">
        <h2 class="text-white mb-6">Step 5: Say Hello</h2>

        <MessageBanner>
          <p class="text-white/70 mb-6 leading-relaxed">
            Open the Meshtastic app, go to Messages, and send a hello message to the Primary
            channel. You'll probably get responses from folks around KC within a few minutes
            (depending on time of day and your coverage).
          </p>

          <p class="text-white/70 mb-6 leading-relaxed">
            You'll definitely get an automated welcome from the KCML node when it discovers your
            node for the first time.
          </p>

          <p class="text-white/50 mb-6 leading-relaxed">
            Don't see any nodes? Check the{' '}
            <a
              href="https://map.kansascitymesh.live"
              target="_blank"
              rel="noopener noreferrer"
              class="text-(--info-400) hover:text-(--info-300) underline">coverage map</a
            >{' '}to see if you're in range. The network is growing but still has gaps.
          </p>

          <p class="text-white/70 leading-relaxed">That's it. You're on the mesh.</p>
        </MessageBanner>
      </section>

      {/* Next Steps */}
      <section class="mb-16 pt-8 border-t border-white/10">
        <h2 class="text-white mb-6">Next Steps</h2>

        <p class="text-white/70 mb-8 leading-relaxed">
          If you want to optimize your antenna, add more nodes, or troubleshoot anything, the
          Discord is full of people who've done this already.
        </p>

        <DiscordButton href={DISCORD_INVITE} trackLabel="get-started-discord">
          Join the Discord
        </DiscordButton>
      </section>
    </article>

    <Footer />
  </div>
</Layout>
