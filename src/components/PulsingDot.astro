---
// Live-status indicator. Meshtastic-brand emerald (intentionally outside the
// sage --success scale; brighter feels "alive").
---

<div class="relative flex items-center justify-center w-3 h-3">
  <div
    class="absolute w-3 h-3 rounded-full animate-ping opacity-75"
    style="background-color: var(--meshtastic-green);"
  ></div>
  <div
    class="relative w-2 h-2 rounded-full"
    style="background-color: var(--meshtastic-green);"
  ></div>
</div>
