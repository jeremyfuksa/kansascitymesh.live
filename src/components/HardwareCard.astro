---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  price: string;
  badge: string;
  description: string;
  color: string;
  image?: ImageMetadata;
}

const { name, price, badge, description, color, image } = Astro.props;
---

<div
  class="group relative bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg overflow-hidden shadow-xl shadow-black/50 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 transition-all"
>
  {/* Gradient accent */}
  <div
    class={`absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r ${color} rounded-t-lg z-10`}
  >
  </div>

  {/* Image */}
  {
    image && (
      <div class="aspect-[4/3] bg-gradient-to-br from-neutral-800 to-neutral-900 overflow-hidden">
        <Image src={image} alt={name} class="w-full h-full object-cover" />
      </div>
    )
  }

  <div class="p-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h3 class="text-xl mb-1 text-white">{name}</h3>
        <span class="text-2xl text-white">{price}</span>
      </div>
      <span
        class={`px-3 py-1 bg-gradient-to-r ${color} text-white rounded-md text-sm font-medium`}
      >
        {badge}
      </span>
    </div>

    <p class="text-white/70 text-[15px] leading-relaxed">{description}</p>
  </div>
</div>
