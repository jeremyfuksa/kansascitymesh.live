---
import { ArrowRight, Signal } from '@lucide/astro';
import FeatureCard from './FeatureCard.astro';
import PrimaryButton from './PrimaryButton.astro';
---

<section class="px-4 py-16 bg-black border-t border-white/10 relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute top-1/2 left-1/4 w-96 h-96 rounded-full blur-3xl"
      style="background-color: var(--success-500); opacity: 0.18;"
    >
    </div>
    <div
      class="absolute top-0 right-1/4 w-80 h-80 rounded-full blur-3xl"
      style="background-color: var(--secondary-600); opacity: 0.18;"
    >
    </div>
  </div>

  <div class="max-w-4xl mx-auto">
    <FeatureCard padding="large">
      <div class="flex flex-col md:flex-row md:items-center gap-6">
        <div
          class="flex-shrink-0 w-14 h-14 bg-[var(--success-500)]/20 rounded-2xl flex items-center justify-center"
        >
          <Signal class="w-7 h-7 text-[var(--success-500)]" />
        </div>

        <div class="flex-1">
          <h2 class="text-2xl md:text-3xl text-white mb-2 tracking-tight">
            Got a rooftop, a tower, or a high spot in the metro?
          </h2>
          <p class="text-white/70 leading-relaxed">
            We're recruiting hosts for the KC Backbone Initiative — hosted nodes that fill
            the metro's east and west edges (Bonner Springs, Independence, Blue Springs)
            and close the I-70 hop chain out to existing outlier nodes in Manhattan and
            Columbia.
          </p>
        </div>

        <div class="flex-shrink-0">
          <PrimaryButton href="/host-a-node">
            <span>Become a host</span>
            <ArrowRight class="w-4 h-4" />
          </PrimaryButton>
        </div>
      </div>
    </FeatureCard>
  </div>
</section>
